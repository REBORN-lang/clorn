// test.rn - basic reborn program to clorn



let struct
{
    let x: int;
    let y: int;
} Point;

let enum Color
{
    let Red;
    let Green := 10;
    let Blue;
};

let add: int = (a: int, b: int)
{
    return a + b;
}

let greet: void = (name: string)
{
    printf("Hello, %s\n", name);
    return;
}

//main: int = () // non-standard 'int' type entry point -- works, uncomment to test
let main: void = ()
{
    printf("=== main() ===\n\n");

    let x: int = 0;
    let y: int = 0;

    printf("insert a number: ");

    // does string work?
    let line: string  = NULL;
    let size: size_t  = 0;
    let read: ssize_t = getline(&line, &size, stdin);
    if read == -1
        printf("getline() error while parsing input\n");

    x = atoi(line);

    printf("insert a second number: ");
    // re-read buffer
    if read = getline(&line, &size, stdin) == -1
        printf("getline() error while parsing input\n");
    y = atoi(line);

    free(line);
    line = NULL;
    size = 0;
    read = 0;

    let sum := add(x, y);

    printf("sum: %d\n", sum);

    if sum > 25
        printf("big number\n");
    elif sum == 30
        printf("exactly 30\n");
    else
        printf("small number\n");

    let i: int = 0;
    while (i < 3) {
        printf("i = %d\n", i);
        i++;
    }

    for (let j: int = 0; j < 3; j++) {
        printf("j = %d\n", j);
    }

    for::5 {
        printf("%d range loop iter\n", _i);
    }

    let letter: char = 'a';
    let code := letter-->int; // C explicit cast
    printf("ascii of a: %d\n", code);

    let p: Point;
    p.x = 4;
    p.y = 8;
    printf("point: %d %d\n", p.x, p.y);

    let end_of_test: bool = true;
    if end_of_test == true:
        printf("end of test.\n");
        return 0;
    else
        return 1;
}
